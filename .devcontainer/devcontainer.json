{
  "name": "PermitArb (Cleveland) - Codespaces",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "postCreateCommand": "bash .devcontainer/postCreateCommand.sh",
  "forwardPorts": [10000],
  "portsAttributes": {
    "10000": { "label": "PermitArb Web", "onAutoForward": "openBrowser" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}
